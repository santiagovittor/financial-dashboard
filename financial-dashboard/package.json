{
  "name": "financial-dashboard",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,json,md}\" --ignore-path .gitignore",
    "db:generate": "turbo db:generate",
    "db:migrate:dev": "turbo db:migrate:dev",
    "db:migrate:deploy": "turbo db:migrate:deploy",
    "db:studio": "turbo db:studio",
    "db:reset": "turbo db:reset",
    "test": "turbo test",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0"
}
