# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://finapp:finapp_dev@localhost:5432/finapp_dev

# ─── Session ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_long_random_secret

# Optional: set to .yourdomain.com to share the session cookie across subdomains.
# Leave unset for dev and for single-domain prod deployments.
# SESSION_COOKIE_DOMAIN=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Credentials from https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match an Authorized Redirect URI registered in Google Cloud Console.
# Dev:  http://localhost:3001/api/v1/auth/google/callback
# Prod: https://api.yourdomain.com/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ─── Owner allowlist ──────────────────────────────────────────────────────────
OWNER_EMAIL=you@gmail.com

# ─── AI Extraction (optional) ────────────────────────────────────────────────
# When set, PDF documents are analyzed by Gemini for structured extraction.
# Get a key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Must be the exact frontend origin (no trailing slash).
# Dev:  http://localhost:5173
# Prod: https://app.yourdomain.com
CORS_ORIGIN=http://localhost:5173

# ─── Frontend URL ─────────────────────────────────────────────────────────────
# Used for post-OAuth redirect. Must be set explicitly in production.
# Dev:  http://localhost:5173
# Prod: https://app.yourdomain.com
FRONTEND_URL=http://localhost:5173
